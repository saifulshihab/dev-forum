model SocialLink {
  id       String @id @default(cuid())
  platform String
  url      String

  user   User?   @relation(fields: [userId], references: [id])
  userId String?
}

model Experience {
  id          String    @id @default(cuid())
  role        String
  company     String
  from        DateTime
  to          DateTime?
  present     Boolean?
  description String?

  user   User?   @relation(fields: [userId], references: [id])
  userId String?
}

model Education {
  id          String    @id @default(cuid())
  institute   String
  from        DateTime
  to          DateTime?
  present     Boolean?
  description String?

  user   User?   @relation(fields: [userId], references: [id])
  userId String?
}

model Skill {
  id   String @id @default(cuid())
  name String

  user   User?   @relation(fields: [userId], references: [id])
  userId String?
}

model Project {
  id          String  @id @default(cuid())
  name        String
  description String?
  url         String?

  user   User?   @relation(fields: [userId], references: [id])
  userId String?
}

enum UserType {
  DEVELOPER
  RECRUITER
}

model User {
  id              String           @id @default(uuid())
  fullName        String
  email           String           @unique
  username        String?          @unique
  dob             DateTime?
  bio             String?
  dpUrl           String?
  websiteUrl      String?
  location        String?
  type            UserType?
  socialLinks     SocialLink[]
  experiences     Experience[]
  educations      Education[]
  skills          Skill[]
  projects        Project[]
  questions       Question[]
  answers         Answer[]
  reactions       Reaction[]
  jobs            Job[]
  jobApplications JobApplication[]
  snippets        Snippet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
